# ========================================
# PR Reviewer Pro - Environment Variables
# ========================================

# -----------------
# Database
# -----------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prreviewer"
REDIS_URL="redis://localhost:6379"

# -----------------
# LLM API Keys
# (User provides their own - at least one required)
# -----------------

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-proj-..."
OPENAI_ORG_ID=""  # Optional

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY="sk-ant-..."

# Google AI Studio (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY="AIza..."

# -----------------
# Git Provider Tokens
# (User provides their own - at least one required)
# -----------------

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Scopes needed: repo, read:user, write:discussion
GITHUB_TOKEN="ghp_..."

# GitLab Personal Access Token (https://gitlab.com/-/profile/personal_access_tokens)
# Scopes needed: api, read_api, read_repository
GITLAB_TOKEN="glpat-..."

# Bitbucket App Password (https://bitbucket.org/account/settings/app-passwords/)
# Permissions needed: Repositories (Read, Write), Pull requests (Read, Write)
BITBUCKET_USERNAME="your-username"
BITBUCKET_APP_PASSWORD="..."

# -----------------
# Application Settings
# -----------------

# Environment
NODE_ENV="development"  # development | production | test

# API Server
PORT=8080
API_BASE_URL="http://localhost:8080"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:8080"
FRONTEND_URL="http://localhost:3000"

# -----------------
# Security
# -----------------

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-random-secret-at-least-32-chars"

# Encryption Key for API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="change-me-to-64-char-hex-string"

# Session Secret
SESSION_SECRET="change-me-to-another-random-secret"
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# Webhook Secret (generate with: openssl rand -hex 16)
WEBHOOK_SECRET="change-me-to-random-webhook-secret"

# -----------------
# Features
# -----------------

# Webhook Base URL (for production deployment)
WEBHOOK_BASE_URL="https://your-domain.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100      # Max requests per window

# Job Queue Settings
QUEUE_CONCURRENCY=5               # Number of concurrent review jobs
QUEUE_MAX_RETRIES=3               # Retry failed jobs
QUEUE_TIMEOUT_MS=300000           # Job timeout: 5 minutes

# -----------------
# Logging & Monitoring
# -----------------

# Log Level: debug | info | warn | error
LOG_LEVEL="info"

# Log Format: json | pretty
LOG_FORMAT="pretty"

# -----------------
# Optional Features
# -----------------

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=""
SLACK_BOT_TOKEN=""

# Sentry (error tracking)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Analytics
ENABLE_ANALYTICS=true
